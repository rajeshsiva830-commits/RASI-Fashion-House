let cart = [];
let selRating = 5;
let currentProdId = null;

const rupee = n => "₹ " + n.toLocaleString("en-IN");
const badgeClass = b => ({new:"prod-badge new",summer:"prod-badge sum",sale:"prod-badge sale",signature:"prod-badge sig"})[b]||"prod-badge";
const badgeLabel = b => ({new:"New In",summer:"☀ Summer",sale:"Sale",signature:"★ Signature"})[b]||b;
const starsHtml = r => {
  const full = Math.floor(r), half = r%1>=0.5;
  let s = "★".repeat(full);
  if(half) s += "✦";
  s += "☆".repeat(5-Math.ceil(r));
  return s;
};

/* ===== RENDER ===== */
function renderProd(filter="all"){
  const grid = document.getElementById("prodGrid");
  const list = filter==="all"?products:products.filter(p=>{
    if(filter==="summer") return p.badge==="summer";
    if(filter==="sale") return p.badge==="sale"||p.orig;
    if(filter==="signature") return p.badge==="signature";
    return p.cat===filter;
  });
  grid.innerHTML = list.map(p=>`
    <div class="prod-card fade-up">
      <div class="prod-img-wrap">
        <img src="${p.img}" alt="${p.name}" loading="lazy"/>
        <div class="prod-hover">
          <button class="quick-add" onclick="addToCart(${p.id},event)">Quick Add to Bag</button>
          <button class="quick-view" onclick="openProduct(${p.id},event)">View Details</button>
        </div>
        ${p.badge?`<span class="${badgeClass(p.badge)}">${badgeLabel(p.badge)}</span>`:""}
        <div class="prod-rating"><span class="star">★</span>${p.rating}</div>
      </div>
      <div class="prod-stars-row"><span class="stars">${starsHtml(p.rating)}</span><span>(${Math.floor(p.rating*10)} reviews)</span></div>
      <div class="prod-name">${p.name}</div>
      <div class="prod-desc">${p.desc}</div>
      <div class="prod-foot">
        <div class="prod-price">${p.orig?`<span class="orig">${rupee(p.orig)}</span>`:""} ${rupee(p.price)}</div>
        <button class="prod-add-btn" onclick="addToCart(${p.id},event)">Add to Bag</button>
      </div>
    </div>
  `).join("");
  grid.querySelectorAll(".fade-up").forEach((el,i)=>setTimeout(()=>obs.observe(el),i*40));
}

function filterProd(filter,btn){
  document.querySelectorAll(".f-tab").forEach(b=>b.classList.remove("active"));
  if(btn) btn.classList.add("active");
  renderProd(filter);
  document.getElementById("collection").scrollIntoView({behavior:"smooth"});
}

/* ===== CART ===== */
function addToCart(id,e){
  if(e){e.stopPropagation();e.preventDefault();}
  const p=products.find(x=>x.id===id); if(!p) return;
  const ex=cart.find(x=>x.id===id);
  if(ex) ex.qty+=1; else cart.push({...p,qty:1,size:"M"});
  updateCart(); showToast(p.name+" added to bag"); openCart();
}

function removeCart(id){cart=cart.filter(x=>x.id!==id);updateCart();}
function changeQty(id,d){
  const it=cart.find(x=>x.id===id); if(!it) return;
  it.qty+=d;
  if(it.qty<=0) removeCart(id); else updateCart();
}

function updateCart(){
  const total=cart.reduce((s,i)=>s+i.qty,0);
  const sub=cart.reduce((s,i)=>s+i.price*i.qty,0);
  const gst=Math.round(sub*0.18);
  const grand=sub+gst;
  const badge=document.getElementById("cartBadge");
  badge.textContent=total; badge.classList.toggle("show",total>0);
  document.getElementById("cartSubLabel").textContent=total===0?"Your bag is empty":`${total} item${total!==1?"s":""} selected`;
  const body=document.getElementById("cartBody");
  const empty=document.getElementById("cartEmpty");
  const foot=document.getElementById("cartFoot");
  if(cart.length===0){
    body.innerHTML=""; body.appendChild(empty); empty.style.display="flex"; foot.style.display="none";
  } else {
    empty.style.display="none"; foot.style.display="block";
    body.innerHTML=cart.map(i=>`
      <div class="cart-item">
        <img class="cart-item-img" src="${i.img}" alt="${i.name}"/>
        <div class="cart-item-info">
          <div class="cart-item-name">${i.name}</div>
          <div class="cart-item-meta">${i.cat==="women"?"Women":"Men"} · Size ${i.size||"M"}</div>
          <div class="cart-item-stars">${starsHtml(i.rating)}</div>
          <div class="cart-controls">
            <button class="qty-btn" onclick="changeQty(${i.id},-1)">−</button>
            <span class="qty-val">${i.qty}</span>
            <button class="qty-btn" onclick="changeQty(${i.id},1)">+</button>
            <button class="cart-item-del" onclick="removeCart(${i.id})">Remove</button>
          </div>
        </div>
        <div class="cart-item-price">${rupee(i.price*i.qty)}</div>
      </div>`).join("");
  }
  document.getElementById("cartSub").textContent=rupee(sub);
  document.getElementById("cartGst").textContent=rupee(gst);
  document.getElementById("cartTotal").textContent=rupee(grand);
}

function openCart(){document.getElementById("cartDrawer").classList.add("open");document.getElementById("cartOverlay").classList.add("open");document.body.style.overflow="hidden";}
function closeCart(){document.getElementById("cartDrawer").classList.remove("open");document.getElementById("cartOverlay").classList.remove("open");document.body.style.overflow="";}

/* ===== PAYMENT ===== */
function openPayment(){
  closeCart();
  const sub=cart.reduce((s,i)=>s+i.price*i.qty,0);
  const gst=Math.round(sub*0.18);
  document.getElementById("orderMini").innerHTML=
    cart.map(i=>`<div class="order-mini-row"><span>${i.name} ×${i.qty}</span><span>${rupee(i.price*i.qty)}</span></div>`).join("")+
    `<div class="order-mini-row"><span>GST (18%)</span><span>${rupee(gst)}</span></div>`+
    `<div class="order-mini-total"><span>Total</span><span>${rupee(sub+gst)}</span></div>`;
  document.getElementById("payModal").classList.add("open");
  document.body.style.overflow="hidden";
}
function closePayment(){document.getElementById("payModal").classList.remove("open");document.body.style.overflow="";}

function selectPay(el){document.querySelectorAll(".pay-tile").forEach(t=>t.classList.remove("on"));el.classList.add("on");}

function formatCard(el){
  let v=el.value.replace(/\D/g,"").substring(0,16);
  el.value=v.replace(/(.{4})/g,"$1  ").trim();
}

function applyCoupon(){
  const code=document.getElementById("couponInput").value.trim().toUpperCase();
  if(code==="RASI15"){showToast("Coupon applied! 15% off above ₹4,999");}
  else{showToast("Invalid or expired coupon code");}
}

function placeOrder(){
  closePayment(); cart=[];
  updateCart();
  showToast("Order placed! Confirmation sent to your email. 🎉");
}

/* ===== TRACKING ===== */
function openTracking(){document.getElementById("trackModal").classList.add("open");document.body.style.overflow="hidden";}
function closeTracking(){document.getElementById("trackModal").classList.remove("open");document.body.style.overflow="";}
function trackOrder(){document.getElementById("trackResult").style.display="block";showToast("Order found — tracking loaded");}

/* ===== PRODUCT MODAL ===== */
function openProduct(id,e){
  if(e){e.stopPropagation();e.preventDefault();}
  const p=products.find(x=>x.id===id); if(!p) return;
  currentProdId=id;
  document.getElementById("pmImg").src=p.img;
  document.getElementById("pmImg").alt=p.name;
  document.getElementById("pmBadge").textContent=p.badge?badgeLabel(p.badge):"Premium";
  document.getElementById("pmName").textContent=p.name;
  document.getElementById("pmStars").textContent=starsHtml(p.rating);
  document.getElementById("pmRatingCount").textContent=`(${p.reviews.length} reviews)`;
  document.getElementById("pmPrice").innerHTML=(p.orig?`<span class="orig">${rupee(p.orig)}</span>`:"")+rupee(p.price);
  document.getElementById("pmDesc").textContent=p.desc;
  document.getElementById("pmAddBtn").onclick=()=>{addToCart(id);closeProdModal();};
  // Reviews
  const rl=document.getElementById("reviewsList");
  rl.innerHTML=p.reviews.map(r=>`
    <div class="review-item">
      <div class="review-top"><span class="stars">${starsHtml(r.stars)}</span><span class="reviewer">${r.name}</span></div>
      <div class="review-text">${r.text}</div>
    </div>`).join("");
  // Star picker reset
  selRating=5;
  document.querySelectorAll(".star-pick").forEach(s=>s.classList.add("lit"));
  document.getElementById("prodModal").classList.add("open");
  document.body.style.overflow="hidden";
}
function closeProdModal(){document.getElementById("prodModal").classList.remove("open");document.body.style.overflow="";}
document.getElementById("prodModal").addEventListener("click",function(e){if(e.target===this)closeProdModal();});

function selectSize(btn){document.querySelectorAll(".size-btn").forEach(b=>b.classList.remove("on"));btn.classList.add("on");}

// Star picker interaction
document.querySelectorAll(".star-pick").forEach(star=>{
  star.addEventListener("click",function(){
    selRating=parseInt(this.dataset.val);
    document.querySelectorAll(".star-pick").forEach((s,i)=>{
      s.classList.toggle("lit",i<selRating);
    });
  });
});

function submitReview(){
  const name=document.getElementById("revName").value.trim();
  const text=document.getElementById("revText").value.trim();
  if(!name||!text){showToast("Please enter your name and review");return;}
  const p=products.find(x=>x.id===currentProdId);
  if(!p) return;
  p.reviews.unshift({name:name+" ✓",stars:selRating,text:text});
  // Re-render reviews
  const rl=document.getElementById("reviewsList");
  rl.innerHTML=p.reviews.map(r=>`
    <div class="review-item">
      <div class="review-top"><span class="stars">${starsHtml(r.stars)}</span><span class="reviewer">${r.name}</span></div>
      <div class="review-text">${r.text}</div>
    </div>`).join("");
  document.getElementById("revName").value="";
  document.getElementById("revText").value="";
  showToast("Review posted! Thank you.");
}

/* ===== TOAST ===== */
let toastTimer;
function showToast(msg){
  const t=document.getElementById("toast");
  document.getElementById("toastMsg").textContent=msg;
  t.classList.add("show"); clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove("show"),3000);
}

/* ===== SCROLL EFFECTS ===== */
const obs=new IntersectionObserver(entries=>{
  entries.forEach((entry,i)=>{if(entry.isIntersecting)setTimeout(()=>entry.target.classList.add("vis"),i*60);});
},{threshold:0.06});
document.querySelectorAll(".fade-up").forEach(el=>obs.observe(el));

// Sticky nav
window.addEventListener("scroll",()=>{
  const nav=document.getElementById("mainNav");
  const scrolled=window.scrollY>60;
  nav.classList.toggle("scrolled",scrolled);
  nav.style.top=scrolled?"0":"40px";
});

/* ===== MOBILE NAV ===== */
function openMobNav(){document.getElementById("mobNav").classList.add("open");document.body.style.overflow="hidden";}
function closeMobNav(){document.getElementById("mobNav").classList.remove("open");document.body.style.overflow="";}

/* ===== INIT ===== */
renderProd("all");
updateCart();
</script>
</body>
</html>
