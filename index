<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  /* Refined Palette — Deep Forest meets Warm Gold */
  --black:#0C0C0C;
  --deep:#111210;
  --forest:#1A1F1A;
  --sage:#2D3B2D;
  --moss:#3D4F3D;
  --gold:#BFA46A;
  --gold-lt:#D4BC8A;
  --gold-pale:rgba(191,164,106,0.1);
  --gold-dim:#9A7F45;
  --cream:#FAF7F2;
  --ivory:#FFFEF9;
  --linen:#F0EAE0;
  --warm:#E8DFD0;
  --stone:#857F74;
  --mist:#AEA89E;
  --white:#FFFFFF;
  --red:#8B2E2E;
  --radius:2px;
}

html{scroll-behavior:smooth;font-size:16px;}
body{font-family:'DM Sans',sans-serif;background:var(--ivory);color:var(--black);overflow-x:hidden;}
img{display:block;max-width:100%;}
a{text-decoration:none;color:inherit;}
button{cursor:pointer;font-family:'DM Sans',sans-serif;}

/* ===== ANNOUNCEMENT BANNER ===== */
.announce-bar{background:var(--forest);color:var(--gold-lt);text-align:center;padding:0.75rem 1rem;font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;position:relative;z-index:600;}
.announce-bar strong{color:var(--white);}

/* ===== NAVIGATION ===== */
nav{position:fixed;top:40px;left:0;right:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:1.2rem 5%;background:rgba(255,254,249,0.95);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid rgba(191,164,106,0.15);transition:all 0.4s;}
nav.scrolled{top:0;box-shadow:0 2px 40px rgba(12,12,12,0.08);}
.logo{display:flex;align-items:center;gap:12px;}
.logo-emblem{width:38px;height:38px;border:1.5px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;position:relative;}
.logo-emblem::after{content:'';position:absolute;width:28px;height:28px;border:0.5px solid rgba(191,164,106,0.4);border-radius:50%;}
.logo-emblem span{font-family:'Cinzel',serif;font-size:1rem;color:var(--gold);position:relative;z-index:1;}
.logo-text{font-family:'Cinzel',serif;font-size:1.2rem;letter-spacing:0.5em;color:var(--black);font-weight:400;}
.nav-center{display:flex;gap:2.5rem;list-style:none;}
.nav-center a{font-size:0.7rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--stone);transition:color 0.25s;}
.nav-center a:hover{color:var(--gold-dim);}
.nav-right{display:flex;align-items:center;gap:1rem;}
.nav-icon-btn{background:none;border:none;width:38px;height:38px;display:flex;align-items:center;justify-content:center;position:relative;transition:opacity 0.2s;}
.nav-icon-btn:hover{opacity:0.7;}
.nav-icon-btn svg{width:20px;height:20px;stroke:var(--black);fill:none;stroke-width:1.4;}
.cart-badge{position:absolute;top:2px;right:2px;background:var(--gold);color:var(--black);font-size:0.5rem;font-weight:600;width:14px;height:14px;border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transform:scale(0);transition:all 0.2s;}
.cart-badge.show{opacity:1;transform:scale(1);}
.nav-shop-btn{font-size:0.62rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--ivory);background:var(--black);padding:0.75rem 1.6rem;border:1px solid var(--black);transition:all 0.3s;}
.nav-shop-btn:hover{background:var(--gold-dim);border-color:var(--gold-dim);}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;padding:6px;}
.hamburger span{display:block;width:22px;height:1.5px;background:var(--black);transition:all 0.3s;}

/* Mobile nav drawer */
.mob-nav{position:fixed;top:0;left:0;right:0;bottom:0;background:var(--forest);z-index:550;display:flex;flex-direction:column;padding:2rem 2rem 3rem;transform:translateX(-100%);transition:transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);}
.mob-nav.open{transform:translateX(0);}
.mob-nav-close{align-self:flex-end;background:none;border:1px solid rgba(191,164,106,0.3);color:var(--gold);padding:0.5rem 1rem;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;margin-bottom:3rem;}
.mob-nav ul{list-style:none;flex:1;}
.mob-nav ul li{border-bottom:1px solid rgba(191,164,106,0.1);padding:1.5rem 0;}
.mob-nav ul a{font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--cream);letter-spacing:0.02em;}
.mob-nav-bottom{display:flex;gap:1rem;}
.mob-nav-bottom .nav-shop-btn{flex:1;text-align:center;padding:1rem;}

/* ===== CART DRAWER ===== */
.cart-overlay{position:fixed;inset:0;background:rgba(12,12,12,0.55);z-index:600;opacity:0;pointer-events:none;transition:opacity 0.35s;backdrop-filter:blur(4px);}
.cart-overlay.open{opacity:1;pointer-events:all;}
.cart-drawer{position:fixed;top:0;right:0;bottom:0;width:min(460px,100vw);background:var(--ivory);z-index:601;display:flex;flex-direction:column;transform:translateX(105%);transition:transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94);}
.cart-drawer.open{transform:translateX(0);}
.cart-head{display:flex;align-items:center;justify-content:space-between;padding:2rem 2rem 1.5rem;border-bottom:1px solid rgba(191,164,106,0.15);}
.cart-head h3{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:400;color:var(--black);}
.cart-head span{font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold);display:block;margin-top:3px;}
.cart-x{background:none;border:1px solid rgba(191,164,106,0.25);width:34px;height:34px;display:flex;align-items:center;justify-content:center;transition:all 0.2s;}
.cart-x:hover{background:var(--linen);}
.cart-x svg{width:12px;height:12px;stroke:var(--black);fill:none;stroke-width:2;}
.cart-body{flex:1;overflow-y:auto;padding:1.5rem 2rem;}
.cart-body::-webkit-scrollbar{width:2px;}
.cart-body::-webkit-scrollbar-thumb{background:rgba(191,164,106,0.3);}
.cart-empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:1rem;text-align:center;}
.cart-empty-state svg{width:50px;height:50px;stroke:var(--mist);fill:none;stroke-width:1;opacity:0.4;}
.cart-empty-state p{font-size:0.82rem;color:var(--stone);line-height:2;letter-spacing:0.04em;}
.cart-item{display:flex;gap:1rem;padding:1.2rem 0;border-bottom:1px solid rgba(191,164,106,0.1);animation:slideRight 0.3s ease;}
@keyframes slideRight{from{opacity:0;transform:translateX(20px);}to{opacity:1;transform:translateX(0);}}
.cart-item-img{width:72px;height:92px;object-fit:cover;background:var(--linen);flex-shrink:0;}
.cart-item-info{flex:1;min-width:0;}
.cart-item-name{font-family:'Playfair Display',serif;font-size:1rem;font-weight:400;color:var(--black);margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cart-item-meta{font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--stone);margin-bottom:0.5rem;}
.cart-item-stars{color:var(--gold);font-size:0.7rem;margin-bottom:0.5rem;}
.cart-controls{display:flex;align-items:center;gap:0.5rem;}
.qty-btn{width:26px;height:26px;border:1px solid rgba(191,164,106,0.3);background:none;display:flex;align-items:center;justify-content:center;font-size:1rem;color:var(--black);transition:all 0.2s;}
.qty-btn:hover{background:var(--linen);}
.qty-val{font-size:0.82rem;min-width:20px;text-align:center;}
.cart-item-del{background:none;border:none;font-size:0.6rem;color:var(--mist);letter-spacing:0.1em;text-transform:uppercase;margin-left:auto;transition:color 0.2s;}
.cart-item-del:hover{color:var(--red);}
.cart-item-price{font-size:0.82rem;color:var(--gold-dim);letter-spacing:0.06em;align-self:flex-start;flex-shrink:0;}
.cart-foot{padding:1.5rem 2rem 2rem;border-top:1px solid rgba(191,164,106,0.15);}
.cart-totals{margin-bottom:1.2rem;}
.cart-row{display:flex;justify-content:space-between;font-size:0.76rem;color:var(--stone);padding:0.28rem 0;letter-spacing:0.04em;}
.cart-row.total{font-size:0.9rem;color:var(--black);border-top:1px solid rgba(191,164,106,0.15);margin-top:0.4rem;padding-top:0.6rem;}
.cart-row.total span:last-child{color:var(--gold-dim);}
.cart-cta{width:100%;padding:1.1rem;background:var(--black);color:var(--ivory);border:none;font-size:0.65rem;letter-spacing:0.25em;text-transform:uppercase;transition:background 0.3s;}
.cart-cta:hover{background:var(--gold-dim);}
.cart-sub-link{display:block;text-align:center;margin-top:0.9rem;font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--stone);background:none;border:none;border-bottom:1px solid rgba(191,164,106,0.3);padding-bottom:2px;width:fit-content;margin-inline:auto;transition:color 0.2s;}
.cart-sub-link:hover{color:var(--gold);}

/* ===== PAYMENT MODAL ===== */
.modal-bg{position:fixed;inset:0;background:rgba(12,12,12,0.8);z-index:700;opacity:0;pointer-events:none;transition:opacity 0.3s;backdrop-filter:blur(10px);}
.modal-bg.open{opacity:1;pointer-events:all;}
.modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-46%);z-index:701;background:var(--ivory);width:min(660px,96vw);max-height:92vh;overflow-y:auto;opacity:0;transition:all 0.4s cubic-bezier(0.25,0.46,0.45,0.94);}
.modal-bg.open .modal{opacity:1;transform:translate(-50%,-50%);}
.modal::-webkit-scrollbar{width:3px;}
.modal::-webkit-scrollbar-thumb{background:rgba(191,164,106,0.3);}
.modal-top{display:flex;align-items:center;justify-content:space-between;padding:2.2rem 2.5rem 1.8rem;border-bottom:1px solid rgba(191,164,106,0.15);}
.modal-top h3{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:400;}
.modal-top small{display:block;font-size:0.58rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold);margin-top:3px;}
.modal-close-btn{background:none;border:1px solid rgba(191,164,106,0.25);width:34px;height:34px;display:flex;align-items:center;justify-content:center;transition:all 0.2s;}
.modal-close-btn:hover{background:var(--linen);}
.modal-close-btn svg{width:12px;height:12px;stroke:var(--black);fill:none;stroke-width:2;}
.modal-content{padding:2.2rem 2.5rem 2.8rem;}
.field-section{font-size:0.58rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--gold);margin:0 0 1.2rem;display:flex;align-items:center;gap:0.7rem;}
.field-section::after{content:'';flex:1;height:1px;background:rgba(191,164,106,0.2);}
.f-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:0;}
.f-group{display:flex;flex-direction:column;gap:0.35rem;margin-bottom:1rem;}
.f-group label{font-size:0.58rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--stone);}
.f-group input,.f-group select{padding:0.85rem 1rem;border:1px solid rgba(191,164,106,0.22);background:transparent;font-family:'DM Sans',sans-serif;font-size:0.82rem;color:var(--black);outline:none;transition:border-color 0.2s;border-radius:var(--radius);}
.f-group input:focus,.f-group select:focus{border-color:var(--gold);}
.f-group input::placeholder{color:var(--mist);}
/* Coupon */
.coupon-row{display:flex;gap:0.6rem;margin-bottom:1.2rem;}
.coupon-row input{flex:1;padding:0.8rem 1rem;border:1px solid rgba(191,164,106,0.22);background:transparent;font-family:'DM Sans',sans-serif;font-size:0.8rem;color:var(--black);outline:none;border-radius:var(--radius);}
.coupon-row input:focus{border-color:var(--gold);}
.coupon-row button{padding:0.8rem 1.4rem;background:none;border:1px solid var(--gold-dim);color:var(--gold-dim);font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;transition:all 0.2s;border-radius:var(--radius);}
.coupon-row button:hover{background:var(--gold-pale);}
/* Pay methods */
.pay-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0.6rem;margin-bottom:1.5rem;}
.pay-tile{border:1px solid rgba(191,164,106,0.2);padding:0.9rem 0.5rem;text-align:center;cursor:pointer;transition:all 0.2s;border-radius:var(--radius);}
.pay-tile:hover,.pay-tile.on{border-color:var(--gold);background:var(--gold-pale);}
.pay-tile i{font-size:1.3rem;display:block;margin-bottom:4px;}
.pay-tile span{font-size:0.54rem;letter-spacing:0.13em;text-transform:uppercase;color:var(--stone);}
.pay-tile.on span{color:var(--gold-dim);}
.order-mini{background:var(--linen);padding:1.2rem 1.5rem;margin-bottom:1.5rem;border-radius:var(--radius);}
.order-mini-row{display:flex;justify-content:space-between;font-size:0.78rem;color:var(--stone);padding:0.28rem 0;}
.order-mini-total{display:flex;justify-content:space-between;font-size:0.88rem;color:var(--black);border-top:1px solid rgba(191,164,106,0.2);margin-top:0.4rem;padding-top:0.6rem;}
.order-mini-total span:last-child{color:var(--gold-dim);}
.pay-cta{width:100%;padding:1.15rem;background:var(--black);color:var(--ivory);border:none;font-size:0.65rem;letter-spacing:0.28em;text-transform:uppercase;transition:background 0.3s;margin-top:1rem;border-radius:var(--radius);}
.pay-cta:hover{background:var(--gold-dim);}
.trust-row{display:flex;gap:0.8rem;justify-content:center;margin-top:1rem;flex-wrap:wrap;}
.trust-row span{font-size:0.56rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--mist);display:flex;align-items:center;gap:0.3rem;}

/* ===== ORDER TRACKING ===== */
.track-step{display:flex;align-items:flex-start;gap:1rem;padding:0.8rem 0;border-left:2px solid rgba(191,164,106,0.2);padding-left:1.2rem;position:relative;margin-left:0.5rem;}
.track-step::before{content:'';position:absolute;left:-5px;top:50%;transform:translateY(-50%);width:8px;height:8px;border-radius:50%;background:var(--linen);border:2px solid rgba(191,164,106,0.4);}
.track-step.done::before{background:var(--gold);border-color:var(--gold);}
.track-step.done{border-color:rgba(191,164,106,0.5);}
.track-label{font-size:0.68rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--black);}
.track-date{font-size:0.6rem;color:var(--stone);margin-top:3px;}

/* ===== PRODUCT DETAIL MODAL ===== */
.prod-modal{width:min(860px,96vw);display:grid;grid-template-columns:1fr 1fr;}
.prod-modal-img{aspect-ratio:3/4;object-fit:cover;}
.prod-modal-body{padding:2.5rem;}
.prod-modal-badge{font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;}
.prod-modal-badge::before{content:'';width:16px;height:1px;background:var(--gold);}
.prod-modal-name{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:400;color:var(--black);line-height:1.2;margin-bottom:0.5rem;}
.prod-modal-rating{display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;}
.stars{color:var(--gold);font-size:0.9rem;letter-spacing:2px;}
.rating-count{font-size:0.7rem;color:var(--stone);}
.prod-modal-price{font-size:1.3rem;color:var(--gold-dim);letter-spacing:0.06em;margin-bottom:1.2rem;}
.prod-modal-price .orig{color:var(--mist);text-decoration:line-through;font-size:0.9rem;margin-right:0.6rem;}
.prod-modal-desc{font-size:0.82rem;line-height:2;color:var(--stone);margin-bottom:1.5rem;}
.size-label{font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--stone);margin-bottom:0.7rem;}
.size-grid{display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1.5rem;}
.size-btn{border:1px solid rgba(191,164,106,0.3);background:none;width:44px;height:44px;font-size:0.7rem;letter-spacing:0.1em;color:var(--stone);transition:all 0.2s;}
.size-btn:hover,.size-btn.on{border-color:var(--black);color:var(--black);background:var(--linen);}
.prod-modal-cta{width:100%;padding:1.1rem;background:var(--black);color:var(--ivory);border:none;font-size:0.62rem;letter-spacing:0.25em;text-transform:uppercase;transition:background 0.3s;margin-bottom:0.8rem;}
.prod-modal-cta:hover{background:var(--gold-dim);}
.prod-modal-wishlist{width:100%;padding:1rem;background:none;border:1px solid rgba(191,164,106,0.3);font-size:0.62rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--black);transition:all 0.2s;}
.prod-modal-wishlist:hover{border-color:var(--gold);color:var(--gold-dim);}
/* Reviews inside modal */
.reviews-section{margin-top:2rem;border-top:1px solid rgba(191,164,106,0.15);padding-top:1.5rem;}
.reviews-title{font-size:0.6rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem;}
.review-item{padding:1rem 0;border-bottom:1px solid rgba(191,164,106,0.1);}
.review-top{display:flex;align-items:center;gap:0.7rem;margin-bottom:0.4rem;}
.review-top .stars{font-size:0.75rem;}
.reviewer{font-size:0.65rem;color:var(--stone);}
.review-text{font-size:0.78rem;line-height:1.8;color:var(--stone);}
.review-form{margin-top:1.5rem;}
.review-form-title{font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--stone);margin-bottom:1rem;}
.star-picker{display:flex;gap:0.3rem;margin-bottom:0.8rem;font-size:1.2rem;cursor:pointer;}
.star-pick{color:var(--mist);transition:color 0.2s;}
.star-pick.lit,.star-pick:hover,.star-pick:hover ~ .star-pick{color:var(--gold);}
.review-form textarea{width:100%;padding:0.8rem 1rem;border:1px solid rgba(191,164,106,0.22);background:transparent;font-family:'DM Sans',sans-serif;font-size:0.8rem;color:var(--black);resize:vertical;min-height:80px;outline:none;border-radius:var(--radius);}
.review-form textarea:focus{border-color:var(--gold);}
.review-submit{padding:0.75rem 1.5rem;background:var(--black);color:var(--ivory);border:none;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;margin-top:0.7rem;transition:background 0.3s;border-radius:var(--radius);}
.review-submit:hover{background:var(--gold-dim);}

/* ===== TOAST ===== */
.toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(80px);background:var(--forest);color:var(--cream);padding:0.9rem 2rem;z-index:900;font-size:0.64rem;letter-spacing:0.18em;text-transform:uppercase;display:flex;align-items:center;gap:0.7rem;opacity:0;transition:all 0.35s;box-shadow:0 8px 40px rgba(12,12,12,0.25);}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.toast-dot{width:5px;height:5px;background:var(--gold);border-radius:50%;flex-shrink:0;}

/* ===== HERO ===== */
.hero{min-height:100vh;display:grid;grid-template-columns:52% 48%;padding-top:80px;}
.hero-left{display:flex;flex-direction:column;justify-content:center;padding:5rem 5% 5rem 7%;}
.hero-kicker{font-size:0.62rem;letter-spacing:0.38em;text-transform:uppercase;color:var(--gold);margin-bottom:3rem;display:flex;align-items:center;gap:1rem;}
.hero-kicker::before{content:'';width:30px;height:1px;background:var(--gold);}
.hero-h1{font-family:'Playfair Display',serif;font-size:clamp(3.5rem,6vw,7rem);font-weight:400;line-height:1.02;color:var(--black);margin-bottom:2.5rem;letter-spacing:-0.02em;}
.hero-h1 em{font-style:italic;color:var(--gold-dim);}
.hero-line{width:48px;height:1.5px;background:var(--gold);margin-bottom:2rem;opacity:0.7;}
.hero-sub{font-size:0.88rem;line-height:2.3;color:var(--stone);max-width:380px;margin-bottom:3.5rem;font-weight:300;letter-spacing:0.04em;}
.hero-actions{display:flex;gap:1.2rem;align-items:center;flex-wrap:wrap;}
.btn-dark{font-size:0.65rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--ivory);background:var(--black);padding:1.1rem 2.8rem;border:1px solid var(--black);transition:all 0.3s;display:inline-block;}
.btn-dark:hover{background:var(--gold-dim);border-color:var(--gold-dim);}
.btn-outline{font-size:0.65rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--black);border-bottom:1.5px solid var(--gold);padding-bottom:3px;transition:color 0.25s;display:inline-block;}
.btn-outline:hover{color:var(--gold-dim);}
.hero-right{background:var(--forest);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;}
.hero-img-main{width:100%;height:100%;object-fit:cover;opacity:0.85;transition:transform 8s ease;}
.hero-img-main:hover{transform:scale(1.03);}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,31,26,0.6) 0%,rgba(26,31,26,0.2) 60%,transparent 100%);}
.hero-brand-stamp{position:absolute;bottom:3rem;left:3rem;z-index:2;}
.hero-stamp-ring{width:120px;height:120px;border:1px solid rgba(191,164,106,0.5);border-radius:50%;display:flex;align-items:center;justify-content:center;position:relative;}
.hero-stamp-ring::before{content:'';position:absolute;width:96px;height:96px;border:0.5px solid rgba(191,164,106,0.25);border-radius:50%;}
.hero-stamp-letter{font-family:'Cinzel',serif;font-size:2.8rem;color:var(--gold);position:relative;z-index:1;}
.hero-stamp-text{margin-top:0.7rem;text-align:center;}
.hero-stamp-text span{display:block;font-size:0.56rem;letter-spacing:0.35em;text-transform:uppercase;color:rgba(191,164,106,0.7);}
.hero-scrollcue{position:absolute;bottom:2.5rem;right:2.5rem;display:flex;flex-direction:column;align-items:center;gap:0.5rem;z-index:2;}
.scroll-line{width:1px;height:50px;background:linear-gradient(to bottom,var(--gold),transparent);animation:scrollPulse 2s ease infinite;}
@keyframes scrollPulse{0%,100%{opacity:0.4;}50%{opacity:1;}}
.scroll-label{font-size:0.52rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold);writing-mode:vertical-rl;transform:rotate(180deg);}
.hero-stats{display:flex;gap:3rem;margin-top:3rem;padding-top:2.5rem;border-top:1px solid rgba(191,164,106,0.12);}
.hero-stat-num{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:400;color:var(--black);display:block;line-height:1;}
.hero-stat-lbl{font-size:0.58rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--stone);margin-top:4px;display:block;}

/* ===== MARQUEE ===== */
.marquee-band{background:var(--black);padding:0.9rem 0;overflow:hidden;white-space:nowrap;}
.marquee-track{display:inline-block;animation:marquee 35s linear infinite;}
.marquee-track span{font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);margin:0 2.5rem;opacity:0.7;}
.marquee-track .sep{opacity:0.3;margin:0 0.6rem;}
@keyframes marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}

/* ===== COLLECTION ===== */
.collection{padding:7rem 5%;background:var(--ivory);}
.section-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.5rem;padding-bottom:2rem;border-bottom:1px solid rgba(191,164,106,0.12);}
.section-label{font-size:0.58rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:0.6rem;}
.section-label::after{content:'';width:20px;height:1px;background:var(--gold);opacity:0.6;}
.section-h2{font-family:'Playfair Display',serif;font-size:clamp(2rem,3vw,3rem);font-weight:400;color:var(--black);line-height:1.1;}
.filter-bar{display:flex;gap:0.4rem;margin-bottom:3.5rem;flex-wrap:wrap;}
.f-tab{font-size:0.6rem;letter-spacing:0.18em;text-transform:uppercase;padding:0.6rem 1.4rem;border:1px solid rgba(191,164,106,0.22);background:none;color:var(--stone);transition:all 0.2s;font-family:'DM Sans',sans-serif;border-radius:var(--radius);}
.f-tab:hover{border-color:var(--gold);color:var(--gold-dim);}
.f-tab.active{background:var(--black);color:var(--ivory);border-color:var(--black);}
.prod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;}
.prod-card{cursor:pointer;}
.prod-img-wrap{aspect-ratio:3/4;background:var(--linen);position:relative;overflow:hidden;margin-bottom:1.2rem;}
.prod-img-wrap img{width:100%;height:100%;object-fit:cover;transition:transform 0.75s cubic-bezier(0.25,0.46,0.45,0.94);}
.prod-card:hover .prod-img-wrap img{transform:scale(1.07);}
.prod-hover{position:absolute;inset:0;background:rgba(12,12,12,0.48);display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:1.5rem;gap:0.5rem;opacity:0;transition:opacity 0.3s;}
.prod-card:hover .prod-hover{opacity:1;}
.quick-add{font-family:'DM Sans',sans-serif;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--ivory);background:rgba(12,12,12,0.6);border:1px solid rgba(191,164,106,0.5);padding:0.7rem 1.5rem;width:100%;transition:all 0.2s;backdrop-filter:blur(8px);}
.quick-add:hover{background:var(--gold-dim);border-color:var(--gold);}
.quick-view{font-size:0.58rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--cream);background:none;border:none;border-bottom:1px solid rgba(191,164,106,0.5);padding-bottom:2px;}
.prod-badge{position:absolute;top:1rem;left:1rem;font-size:0.52rem;letter-spacing:0.2em;text-transform:uppercase;background:var(--black);color:var(--ivory);padding:0.3rem 0.7rem;}
.prod-badge.new{background:var(--gold-dim);}
.prod-badge.sale{background:var(--red);}
.prod-badge.sig{background:var(--sage);color:var(--gold-lt);}
.prod-badge.sum{background:var(--moss);color:var(--cream);}
.prod-rating{position:absolute;top:1rem;right:1rem;background:rgba(255,254,249,0.92);backdrop-filter:blur(4px);padding:0.3rem 0.5rem;display:flex;align-items:center;gap:3px;font-size:0.62rem;color:var(--black);}
.prod-rating .star{color:var(--gold);}
.prod-name{font-family:'Playfair Display',serif;font-size:1.08rem;font-weight:400;color:var(--black);margin-bottom:0.2rem;line-height:1.3;}
.prod-desc{font-size:0.71rem;color:var(--stone);line-height:1.8;margin-bottom:0.5rem;}
.prod-foot{display:flex;justify-content:space-between;align-items:center;}
.prod-price{font-size:0.88rem;color:var(--gold-dim);letter-spacing:0.06em;}
.prod-price .orig{color:var(--mist);text-decoration:line-through;font-size:0.74rem;margin-right:0.4rem;}
.prod-stars-row{display:flex;align-items:center;gap:4px;margin-bottom:0.4rem;}
.prod-stars-row .stars{font-size:0.7rem;}
.prod-stars-row span{font-size:0.6rem;color:var(--stone);}
.prod-add-btn{font-size:0.56rem;letter-spacing:0.18em;text-transform:uppercase;background:none;border:1px solid rgba(191,164,106,0.35);padding:0.45rem 0.9rem;color:var(--black);transition:all 0.2s;font-family:'DM Sans',sans-serif;border-radius:var(--radius);}
.prod-add-btn:hover{background:var(--black);color:var(--ivory);border-color:var(--black);}

/* ===== EDITORIAL / FEATURE PANELS ===== */
.feature-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px;padding:0 5% 7rem;}
.feat-panel{position:relative;overflow:hidden;aspect-ratio:4/3;cursor:pointer;}
.feat-panel img{width:100%;height:100%;object-fit:cover;transition:transform 0.75s cubic-bezier(0.25,0.46,0.45,0.94);}
.feat-panel:hover img{transform:scale(1.05);}
.feat-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(12,12,12,0.75) 0%,rgba(12,12,12,0.1) 55%,transparent 100%);display:flex;align-items:flex-end;padding:2.5rem;}
.feat-content{}
.feat-tag{font-size:0.55rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:0.5rem;}
.feat-title{font-family:'Playfair Display',serif;font-size:clamp(1.5rem,2.2vw,2.2rem);font-weight:400;color:var(--cream);line-height:1.15;margin-bottom:0.8rem;}
.feat-cta{font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--cream);background:none;border:none;border-bottom:1px solid rgba(191,164,106,0.5);padding-bottom:2px;font-family:'DM Sans',sans-serif;transition:color 0.2s;}
.feat-cta:hover{color:var(--gold);}

/* ===== VALUES STRIP ===== */
.values-strip{display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid rgba(191,164,106,0.1);border-bottom:1px solid rgba(191,164,106,0.1);}
.val-item{padding:3.5rem 3rem;border-right:1px solid rgba(191,164,106,0.1);text-align:center;}
.val-item:last-child{border-right:none;}
.val-icon{font-size:1.5rem;margin-bottom:1rem;display:block;}
.val-title{font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--black);margin-bottom:0.6rem;font-weight:500;}
.val-desc{font-size:0.74rem;line-height:1.9;color:var(--stone);}

/* ===== PHILOSOPHY ===== */
.philosophy{padding:9rem 5%;display:grid;grid-template-columns:220px 1fr;gap:7rem;background:var(--linen);}
.phil-sidebar{padding-top:1rem;}
.phil-sidebar-label{font-size:0.58rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);display:flex;flex-direction:column;gap:0.7rem;}
.phil-sidebar-label::before{content:'';display:block;width:1px;height:60px;background:var(--gold);opacity:0.5;margin:0 auto;}
.phil-body h2{font-family:'Playfair Display',serif;font-size:clamp(2.2rem,3.8vw,3.5rem);font-weight:400;line-height:1.15;color:var(--black);margin-bottom:2.5rem;letter-spacing:-0.01em;}
.phil-body p{font-size:0.86rem;line-height:2.2;color:var(--stone);margin-bottom:1.4rem;font-weight:300;}
.phil-sep{width:44px;height:1.5px;background:var(--gold);margin:2.5rem 0;opacity:0.6;}

/* ===== VISION / MISSION ===== */
.vm-section{background:var(--black);padding:9rem 5%;display:grid;grid-template-columns:1fr 1fr;gap:1px;position:relative;overflow:hidden;}
.vm-section::before{content:'RASI';position:absolute;font-family:'Cinzel',serif;font-size:30vw;font-weight:400;color:rgba(255,255,255,0.015);bottom:-4rem;left:50%;transform:translateX(-50%);pointer-events:none;user-select:none;white-space:nowrap;}
.vm-card{padding:5rem 5rem 5rem 0;}
.vm-card:last-child{padding:5rem 0 5rem 5rem;border-left:1px solid rgba(191,164,106,0.1);}
.vm-num{font-family:'Playfair Display',serif;font-size:5rem;font-weight:400;color:rgba(191,164,106,0.08);line-height:1;margin-bottom:2rem;}
.vm-tag{font-size:0.58rem;letter-spacing:0.35em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;display:flex;align-items:center;gap:0.8rem;}
.vm-tag::before{content:'';width:18px;height:1px;background:var(--gold);opacity:0.5;}
.vm-h{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,2.6vw,2.5rem);font-weight:400;color:var(--cream);line-height:1.25;margin-bottom:2rem;}
.vm-h em{font-style:italic;color:var(--gold-lt);}
.vm-p{font-size:0.82rem;line-height:2.1;color:var(--mist);margin-bottom:1.4rem;}
.vm-pillars{margin-top:2rem;display:flex;flex-direction:column;gap:0.9rem;}
.vm-pillar{display:flex;align-items:flex-start;gap:1rem;}
.vm-dot{width:4px;height:4px;background:var(--gold);border-radius:50%;flex-shrink:0;margin-top:0.55rem;}
.vm-pillar-text{font-size:0.78rem;color:var(--mist);line-height:1.8;}
.vm-pillar-text strong{color:var(--gold-lt);font-weight:400;}

/* ===== STORY ===== */
.story{background:var(--forest);padding:9rem 5%;display:grid;grid-template-columns:1fr 1.2fr;gap:7rem;align-items:start;}
.story-frame{position:relative;}
.story-frame::before{content:'';position:absolute;top:-14px;left:-14px;right:14px;bottom:14px;border:1px solid rgba(191,164,106,0.25);z-0;pointer-events:none;}
.story-portrait{width:100%;aspect-ratio:3/4;object-fit:cover;object-position:center top;position:relative;z-index:1;}
.story-tag{position:absolute;bottom:-2rem;right:-2rem;background:var(--gold-dim);color:var(--ivory);padding:1.2rem 1.5rem;z-index:2;text-align:center;}
.story-tag strong{display:block;font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:400;font-style:italic;margin-bottom:3px;}
.story-tag small{font-size:0.54rem;letter-spacing:0.18em;text-transform:uppercase;}
.story-chips{display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:3.5rem;}
.story-chip{font-size:0.56rem;letter-spacing:0.18em;text-transform:uppercase;border:1px solid rgba(191,164,106,0.25);color:var(--mist);padding:0.3rem 0.9rem;}
.story-text .section-label{color:var(--gold);margin-bottom:2rem;}
.story-text h2{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,2.8vw,2.6rem);font-weight:400;color:var(--cream);line-height:1.22;margin-bottom:2.5rem;}
.story-text p{font-size:0.84rem;line-height:2.15;color:var(--mist);margin-bottom:1.4rem;}
.story-quote{margin:2rem 0;border-left:2px solid var(--gold-dim);padding:1.2rem 1.8rem;background:rgba(191,164,106,0.04);}
.story-quote p{font-family:'Playfair Display',serif;font-size:1.1rem;font-style:italic;color:var(--gold-lt);line-height:1.65;margin:0;}
.story-numbers{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(191,164,106,0.12);margin:2.5rem 0;}
.story-num-item{background:var(--forest);padding:1.4rem 1rem;text-align:center;}
.story-num{font-family:'Playfair Display',serif;font-size:2rem;font-weight:400;color:var(--gold-lt);display:block;line-height:1;}
.story-num-lbl{font-size:0.54rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--mist);margin-top:4px;display:block;}
.story-sig{font-family:'Playfair Display',serif;font-style:italic;font-size:1.5rem;color:var(--warm);margin-top:3rem;border-top:1px solid rgba(191,164,106,0.18);padding-top:2rem;}
.story-sig small{display:block;font-style:normal;font-family:'DM Sans',sans-serif;font-size:0.56rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--gold);margin-top:4px;}

/* ===== AUDIENCE ===== */
.audience{background:var(--linen);padding:8rem 5%;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;}
.audience-copy h2{font-family:'Playfair Display',serif;font-size:clamp(2rem,3.2vw,3rem);font-weight:400;color:var(--black);line-height:1.18;margin-bottom:1.5rem;margin-top:1.2rem;}
.audience-copy p{font-size:0.84rem;line-height:2.1;color:var(--stone);margin-bottom:1.2rem;}
.audience-mosaic{display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;}
.audience-tile{position:relative;overflow:hidden;aspect-ratio:3/4;cursor:pointer;}
.audience-tile img{width:100%;height:100%;object-fit:cover;transition:transform 0.65s cubic-bezier(0.25,0.46,0.45,0.94);}
.audience-tile:hover img{transform:scale(1.06);}
.audience-label{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(to top,rgba(12,12,12,0.75) 0%,transparent 100%);padding:2rem 1rem 1rem;font-size:0.58rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--cream);}

/* ===== TESTIMONIALS ===== */
.testimonials{padding:8rem 5%;background:var(--ivory);text-align:center;}
.test-head{margin-bottom:3.5rem;}
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;}
.test-card{background:var(--linen);padding:2.5rem 2rem;text-align:left;position:relative;}
.test-quote-mark{font-family:'Playfair Display',serif;font-size:4rem;line-height:1;color:rgba(191,164,106,0.15);position:absolute;top:1rem;right:1.5rem;}
.test-body{font-size:0.82rem;line-height:2;color:var(--stone);margin-bottom:1.5rem;font-style:italic;}
.test-stars{color:var(--gold);font-size:0.8rem;margin-bottom:0.8rem;}
.test-author{font-size:0.64rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--black);}
.test-location{font-size:0.58rem;color:var(--stone);margin-top:2px;}

/* ===== NEWSLETTER ===== */
.newsletter{padding:7rem 5%;text-align:center;background:var(--black);position:relative;overflow:hidden;}
.newsletter::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:600px;border:1px solid rgba(191,164,106,0.05);border-radius:50%;pointer-events:none;}
.newsletter::after{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:400px;height:400px;border:1px solid rgba(191,164,106,0.04);border-radius:50%;pointer-events:none;}
.newsletter .section-label{display:inline-flex;color:var(--gold);margin-bottom:1.5rem;}
.newsletter h2{font-family:'Playfair Display',serif;font-size:clamp(2rem,3vw,3rem);font-weight:400;color:var(--cream);margin-bottom:1rem;position:relative;z-index:1;}
.newsletter p{font-size:0.82rem;color:var(--mist);margin-bottom:3rem;position:relative;z-index:1;letter-spacing:0.04em;}
.nl-row{display:flex;max-width:460px;margin:0 auto;border:1px solid rgba(191,164,106,0.3);position:relative;z-index:1;}
.nl-row input{flex:1;padding:1.1rem 1.3rem;border:none;outline:none;font-family:'DM Sans',sans-serif;font-size:0.8rem;background:transparent;color:var(--cream);}
.nl-row input::placeholder{color:rgba(174,168,158,0.4);}
.nl-row button{padding:1.1rem 1.8rem;background:var(--gold-dim);color:var(--ivory);border:none;font-size:0.6rem;letter-spacing:0.25em;text-transform:uppercase;font-family:'DM Sans',sans-serif;transition:background 0.3s;}
.nl-row button:hover{background:var(--gold);}

/* ===== FOOTER ===== */
footer{padding:5rem 5% 3rem;display:grid;grid-template-columns:2.2fr 1fr 1fr 1fr;gap:4rem;background:var(--deep);border-top:1px solid rgba(191,164,106,0.08);}
.footer-brand p{font-size:0.76rem;line-height:2;color:var(--mist);max-width:230px;margin-top:1rem;}
.footer-socials{display:flex;gap:0.7rem;margin-top:1.5rem;}
.social-btn{width:34px;height:34px;border:1px solid rgba(191,164,106,0.2);display:flex;align-items:center;justify-content:center;color:var(--mist);font-size:0.7rem;transition:all 0.2s;}
.social-btn:hover{border-color:var(--gold);color:var(--gold);}
.footer-col h4{font-size:0.58rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;}
.footer-col ul{list-style:none;}
.footer-col li{margin-bottom:0.75rem;}
.footer-col a{font-size:0.76rem;color:var(--mist);transition:color 0.2s;letter-spacing:0.03em;}
.footer-col a:hover{color:var(--gold);}
.footer-bottom{padding:1.5rem 5%;display:flex;justify-content:space-between;align-items:center;background:var(--deep);border-top:1px solid rgba(191,164,106,0.06);font-size:0.6rem;color:rgba(174,168,158,0.35);letter-spacing:0.12em;}
.footer-bottom a{color:rgba(174,168,158,0.35);transition:color 0.2s;}
.footer-bottom a:hover{color:var(--gold);}

/* ===== ANIMATIONS ===== */
.fade-up{opacity:0;transform:translateY(30px);transition:opacity 0.9s ease,transform 0.9s ease;}
.fade-up.vis{opacity:1;transform:translateY(0);}

/* ===== RESPONSIVE ===== */
@media(max-width:1200px){
  .prod-grid{grid-template-columns:repeat(3,1fr);}
}
@media(max-width:960px){
  nav{padding:1.2rem 5%;}
  .nav-center{display:none;}
  .hamburger{display:flex;}
  .hero{grid-template-columns:1fr;}
  .hero-right{min-height:60vw;}
  .hero-left{padding:4rem 5%;}
  .philosophy{grid-template-columns:1fr;gap:2rem;padding:5rem 5%;}
  .vm-section{grid-template-columns:1fr;padding:5rem 5%;}
  .vm-card,.vm-card:last-child{padding:3rem 0;border-left:none;border-top:1px solid rgba(191,164,106,0.1);}
  .feature-grid{grid-template-columns:1fr;padding:0 5% 5rem;}
  .values-strip{grid-template-columns:1fr 1fr;}
  .val-item{border-right:none;border-bottom:1px solid rgba(191,164,106,0.1);}
  .prod-grid{grid-template-columns:repeat(2,1fr);}
  .story{grid-template-columns:1fr;padding:5rem 5%;gap:4rem;}
  .audience{grid-template-columns:1fr;padding:5rem 5%;}
  .test-grid{grid-template-columns:1fr;}
  footer{grid-template-columns:1fr 1fr;padding:3rem 5%;gap:2.5rem;}
  .footer-bottom{flex-direction:column;gap:0.5rem;text-align:center;padding:1.5rem 5%;}
  .prod-modal{grid-template-columns:1fr;}
  .prod-modal-img{aspect-ratio:4/3;}
  .pay-grid{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:600px){
  .hero-h1{font-size:3rem;}
  .prod-grid{grid-template-columns:1fr 1fr;gap:1rem;}
  .audience-mosaic{grid-template-columns:1fr 1fr;}
  .values-strip{grid-template-columns:1fr;}
